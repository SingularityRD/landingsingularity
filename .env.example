# Server
HOST=127.0.0.1
PORT=8092
NODE_ENV=development

# Public base URL used as fallback for redirects.
# Set these to the real production origins in Cloud Run / local tunnel setups.
PUBLIC_BASE_URL=http://localhost:8092
MARKETING_BASE_URL=http://localhost:8092
APP_BASE_URL=http://localhost:8092

# Reverse-proxy / TLS termination
# - Set TRUST_PROXY_HEADERS=1 if a trusted proxy sets X-Forwarded-For/X-Forwarded-Proto
TRUST_PROXY_HEADERS=0

# If enabled, non-HTTPS requests redirect to https://PUBLIC_BASE_URL (or https://Host)
ENFORCE_HTTPS=0

# HSTS (set only in production over HTTPS, e.g. 15552000 for ~180 days)
HSTS_MAX_AGE_SECONDS=0

# Firebase Auth (customer + admin)
# Production: configure these from the real Firebase project.
# Local dev: you may point at a test project or use the dev helper below.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
# Prefer Workload Identity / GOOGLE_APPLICATION_CREDENTIALS in production.
# If you must bootstrap locally, use a temporary service-account JSON here.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Local-only helper; never enable in production.
FIREBASE_AUTH_DEV_MODE=0

# Admin access control
# Production: list allowlisted admin emails explicitly; leave empty only in local dev.
ADMIN_ALLOWLIST_EMAILS=
# Emergency local fallback only; Firebase admin claims are the production path.
ADMIN_BASIC_AUTH_FALLBACK=0
# ADMIN_BASIC_AUTH_USER=admin
# ADMIN_BASIC_AUTH_PASS=replace-with-strong-password
RATE_LIMIT_ADMIN_AUTH_PER_WINDOW=30

# Session / impersonation TTLs
# Keep these explicit in prod so cookie lifetimes are intentional and reviewable.
PORTAL_COOKIE_TTL_MS=1209600000
ADMIN_SESSION_COOKIE_TTL_MS=28800000
SUPPORT_IMPERSONATION_TTL_MS=900000

# AutoSecOps Commercial API (server-side only)
# Production: point at the internal commercial API base URL.
# Local dev: use the local AutoSecOps server on :8080.
AUTOSECOPS_COMMERCIAL_API_BASE_URL=https://localhost:8080
# Local dev only when AutoSecOps uses a self-signed dev certificate.
AUTOSECOPS_COMMERCIAL_API_ALLOW_INSECURE_TLS=0

# Bearer token for /api/v1/commercial/* endpoints (DO NOT expose to browser)
# Production: store this in Secret Manager / environment only.
AUTOSECOPS_COMMERCIAL_API_TOKEN=replace-with-commercial-token
AUTOSECOPS_COMMERCIAL_AUTH_HEADER=Authorization
AUTOSECOPS_COMMERCIAL_AUTH_SCHEME=Bearer
# Optional overrides (defaults already point to /api/v1/commercial/admin/*)
# AUTOSECOPS_COMMERCIAL_TENANTS_PATH=/api/v1/commercial/admin/tenants
# AUTOSECOPS_COMMERCIAL_IMPERSONATION_START_PATH=/api/v1/commercial/admin/impersonation/start
# AUTOSECOPS_COMMERCIAL_IMPERSONATION_REVOKE_PATH=/api/v1/commercial/admin/impersonation/revoke
# AUTOSECOPS_COMMERCIAL_WEBHOOK_EVENTS_PATH=/api/v1/commercial/admin/webhooks/events
# AUTOSECOPS_COMMERCIAL_WEBHOOK_REPLAY_PATH=/api/v1/commercial/admin/webhooks/replay
# AUTOSECOPS_COMMERCIAL_AUDIT_EVENTS_PATH=/api/v1/commercial/admin/audit/events

# Portal session cookie signing secret (32+ random bytes recommended)
# Production: generate a long random secret and store it in Secret Manager.
PORTAL_COOKIE_SECRET=replace-with-long-random-secret
CUSTOMER_SESSION_COOKIE_NAME=customer_session
CUSTOMER_CSRF_COOKIE_NAME=customer_csrf
ADMIN_SESSION_COOKIE_NAME=admin_session
ADMIN_CSRF_COOKIE_NAME=admin_csrf
